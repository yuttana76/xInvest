# xInvest Environment Variables Template
# Copy this file to .env or .env.dev and fill in the values

# Django
DEBUG=True
SECRET_KEY=django-insecure-replace-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1
FRONTEND_URL=http://localhost:3000

# JWT Auth
JWT_SECRET_KEY=change-this-to-a-secure-random-string
JWT_ALGORITHM=HS256

# Database
POSTGRES_DB=invest_db
POSTGRES_USER=invest_user
POSTGRES_PASSWORD=invest_pass
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1

# External APIs (Get your own keys)
NEWS_API_KEY=your_news_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
FINANCE_API_KEY=your_finance_api_key_here

# FundConnext Integration
FC_API_URL=https://api.fundconnext.com
FC_API_USER=your_user
FC_API_PASSWORD=your_password

# Email Settings
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
DEFAULT_FROM_EMAIL=your_email@gmail.com

# Frontend branding (public, baked into the Next.js build)
NEXT_PUBLIC_APP_NAME=xInvest
NEXT_PUBLIC_APP_TAGLINE=Smart Investment Intelligence

# PDF export branding (backend/workflow/pdf_service.py — IT Request PDF export).
# Leave blank to render a text-only header with no company block.
# Drop the logo at ./branding/logo.png (repo root) — bind-mounted into the
# backend container at /app/branding by docker-compose, no rebuild needed.
PDF_COMPANY_NAME=
PDF_COMPANY_ADDRESS=
PDF_LOGO_PATH=/app/branding/logo.png
