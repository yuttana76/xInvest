# Django
DEBUG=True
SECRET_KEY=prod_secret_key_change_me
ALLOWED_HOSTS=localhost,127.0.0.1,backend,backend.cvo12.net
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://backend.cvo12.net




# DATABASE_URL=postgres://invest_user:invest_pass@db:5432/invest_db
POSTGRES_DB=invest_db
POSTGRES_USER=invest_user
POSTGRES_PASSWORD=invest_pass
POSTGRES_HOST=db
POSTGRES_PORT=5432




# Next.js
NEXT_PUBLIC_API_URL=http://localhost/api
NEXTAUTH_SECRET=auth_secret_change_me_too




# External APIs
FINANCE_API_KEY=your_key_here




# PostgREST
PGRST_DB_URI=postgres://invest_user:invest_pass@db:5432/invest_db
PGRST_DB_SCHEMA=public
PGRST_DB_ANON_ROLE=invest_user




# PostgreSQL Connection Details (Used by Django)
POSTGRES_HOST=db
POSTGRES_PORT=5432




# URL Configuration
FRONTEND_URL=http://localhost:3000




# Email (Gmail SMTP)
# ใส่ Gmail และ App Password ที่สร้างจาก Google Account → Security → App passwords
EMAIL_HOST_USER=your_gmail@gmail.com
EMAIL_HOST_PASSWORD=your_app_password_here
DEFAULT_FROM_EMAIL=noreply@xinvest.com




# PDF export branding (IT Request PDF export) — leave blank for a text-only header.
# Drop the logo at ./branding/logo.png (repo root) to swap it without a rebuild.
PDF_COMPANY_NAME=<Company name>
PDF_COMPANY_ADDRESS= Bangokok Thailand 10501
PDF_LOGO_PATH=/app/branding/logo.png




# Cloudflare Tunnel Token
TUNNEL_TOKEN=<Tunnel Token>

